{
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "autoAllowBashIfSandboxed": false,
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": ["docker *", "yarn *"],
    "filesystem": {
      "allowRead": [
        ".",
        "~/.claude",
        "~/ghq/github.com/korryu3/dotfiles",
        "/private/tmp",
        "~/.cache",
        "~/.yarn",
        "~/.volta",
        "~/.local/share",
        "~/.local/bin",
        "~/.prefect",
        "~/.serena",
        "~/.gitconfig",
        "~/.config/git",
        "~/.config/gh",
        "~/.ssh/id_ed25519.pub",
        "~/.ssh/known_hosts",
        "/**/.pnp.cjs",
        "/private/etc/ssl/cert.pem",
        "~/ghq/**/.git/**"
      ],
      "denyRead": [
        "~/",
        "/**/*.env*",
        "/**/*id_rsa*",
        "/**/*id_ed25519*",
        "/**/*.key*",
        "/**/*.pem*",
        "/**/*.crt*",
        "/**/*.p12*",
        "/**/*.pfx*",
        "/**/*.jks*"
      ],
      "allowWrite": [
        ".",
        "/private/tmp",
        "~/.cache/uv",
        "~/.cache/yarn",
        "~/.yarn",
        "~/.claude/context",
        "~/.prefect",
        "~/.serena",
        "~/ghq/**/.git/**"
      ],
      "denyWrite": [
        "/**/*.env*",
        "/**/*id_rsa*",
        "/**/*id_ed25519*",
        "/**/*.key*",
        "/**/*.pem*",
        "/**/*.crt*",
        "/**/*.p12*",
        "/**/*.pfx*",
        "/**/*.jks*",
        "/**/.claude/settings.json",
        "/**/.claude/settings.local.json"
      ]
    },
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "codeload.github.com",
        "objects.githubusercontent.com",
        "raw.githubusercontent.com",
        "registry.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org",
        "files.pythonhosted.org"
      ],
      "allowUnixSockets": ["/private/tmp"]
    }
  },
  "permissions": {
    "defaultMode": "auto",
    "allow": [],
    "deny": [
      "Read(//**/*.env*)",
      "Read(//**/*id_rsa*)",
      "Read(//**/*id_ed25519*)",
      "Read(//**/*.key*)",
      "Read(//**/*.pem*)",
      "Read(//**/*.crt*)",
      "Read(//**/*.p12*)",
      "Read(//**/*.pfx*)",
      "Read(//**/*.jks*)",
      "Write(~/ghq/**/.git/**)",
      "Write(//**/*.env*)",
      "Write(//**/*id_rsa*)",
      "Write(//**/*id_ed25519*)",
      "Write(//**/*.key*)",
      "Write(//**/*.pem*)",
      "Write(//**/*.crt*)",
      "Write(//**/*.p12*)",
      "Write(//**/*.pfx*)",
      "Write(//**/*.jks*)",
      "Write(//**/.claude/settings.json)",
      "Write(//**/.claude/settings.local.json)",
      "Edit(~/ghq/**/.git/**)",
      "Edit(//**/*.env*)",
      "Edit(//**/*id_rsa*)",
      "Edit(//**/*id_ed25519*)",
      "Edit(//**/*.key*)",
      "Edit(//**/*.pem*)",
      "Edit(//**/*.crt*)",
      "Edit(//**/*.p12*)",
      "Edit(//**/*.pfx*)",
      "Edit(//**/*.jks*)",
      "Edit(//**/.claude/settings.json)",
      "Edit(//**/.claude/settings.local.json)",
      "Bash(sudo *)",
      "Bash(git worktree prune *)",
      "Bash(git worktree remove *)",
      "Bash(rmdir *)",
      "Bash(xargs rm *)",
      "Bash(git config --global *)",
      "Bash(git config --system *)",
      "Bash(git config --unset *)",
      "Bash(brew install *)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(chown *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Bash(git branch -D *)",
      "Bash(git clean *)",
      "Bash(git stash drop *)",
      "Bash(git stash clear *)",
      "Bash(git reflog expire --all *)",
      "Bash(git gc --prune=now)",
      "Bash(uv run alembic downgrade *)",
      "Bash(make drop *)",
      "Bash(bash -c *)",
      "Bash(sh -c *)",
      "Bash(zsh -c *)",
      "Bash(eval *)",
      "Bash(find * -delete*)",
      "Bash(find * -exec rm*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)"
    ],
    "ask": [
      "Bash(git config user.* *)",
      "Bash(git config core.* *)",
      "Bash(git push *)",
      "Bash(git tag -d *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- *)",
      "Bash(git restore *)",
      "Bash(git worktree add *)",
      "Bash(git worktree unlock)",
      "Bash(git worktree move *)",
      "Bash(rm *)"
    ]
  },
  "env": {
    "CHOKIDAR_USEPOLLING": "true"
  },
  "outputStyle": "Explanatory"
}
