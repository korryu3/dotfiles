{
  "cleanupPeriodDays": 9999,
  "permissions": {
    "allow": [
      "Bash(mkdir -p ~/.claude/context/**)",
      "Bash(~/.claude/scripts/project-id.sh)",
      "Read(~/.claude/context/**)",
      "Write(~/.claude/context/**)",
      "Edit(~/.claude/context/**)",
      "MultiEdit(~/.claude/context/**)",
      "Skill(creating-plan)",
      "Skill(resuming-session)",
      "Skill(saving-session)",
      "Skill(skill-creator)",
      "Skill(tdd)",
      "Skill(nvim-sensei)",
      "Skill(reviewing-code)"
    ],
    "deny": [
      "Read(//**/secrets/**)",
      "Read(//**/.aws/**)",
      "Read(//**/.ssh/**)",
      "Read(//**/*.env*)",
      "Read(//**/*id_rsa*)",
      "Read(//**/*id_ed25519*)",
      "Read(//**/*.key*)",
      "Read(//**/*.pem*)",
      "Read(//**/*.crt*)",
      "Read(//**/*.p12*)",
      "Read(//**/*.pfx*)",
      "Read(//**/*.jks*)",
      "Write(//**/*.env*)",
      "Write(//**/*id_rsa*)",
      "Write(//**/*id_ed25519*)",
      "Write(//**/*.key*)",
      "Write(//**/*.pem*)",
      "Write(//**/*.crt*)",
      "Write(//**/*.p12*)",
      "Write(//**/*.pfx*)",
      "Write(//**/*.jks*)",
      "Write(//**/.git/**)",
      "Write(//**/.claude/settings.json)",
      "Write(//**/.claude/settings.local.json)",
      "Edit(//**/*.env*)",
      "Edit(//**/*id_rsa*)",
      "Edit(//**/*id_ed25519*)",
      "Edit(//**/*.key*)",
      "Edit(//**/*.pem*)",
      "Edit(//**/*.crt*)",
      "Edit(//**/*.p12*)",
      "Edit(//**/*.pfx*)",
      "Edit(//**/*.jks*)",
      "Edit(//**/.git/**)",
      "Edit(//**/.claude/settings.json)",
      "Edit(//**/.claude/settings.local.json)",
      "MultiEdit(//**/*.env*)",
      "MultiEdit(//**/*id_rsa*)",
      "MultiEdit(//**/*id_ed25519*)",
      "MultiEdit(//**/*.key*)",
      "MultiEdit(//**/*.pem*)",
      "MultiEdit(//**/*.crt*)",
      "MultiEdit(//**/*.p12*)",
      "MultiEdit(//**/*.pfx*)",
      "MultiEdit(//**/*.jks*)",
      "MultiEdit(//**/.git/**)",
      "MultiEdit(//**/.claude/settings.json)",
      "MultiEdit(//**/.claude/settings.local.json)",
      "Bash(find * -delete*)",
      "Bash(find * -exec rm*)",
      "Bash(git branch -D *)",
      "Bash(git clean *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Bash(xargs rm *)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(chown *)",
      "Bash(sudo *)",
      "Bash(bash -c *)",
      "Bash(eval *)",
      "Bash(sh -c *)",
      "Bash(zsh -c *)",
      "Bash(curl * | bash*)",
      "Bash(curl * | sh*)",
      "Bash(brew install *)",
      "Bash(git config *)"
    ],
    "ask": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(git branch *)"
    ]
  },
  "model": "claude-opus-4-6[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/guard-pr-posting.sh",
            "if": "Bash(gh pr comment*)"
          },
          {
            "type": "command",
            "command": "~/.claude/scripts/guard-pr-posting.sh",
            "if": "Bash(gh pr review*)"
          },
          {
            "type": "command",
            "command": "~/.claude/scripts/guard-pr-posting.sh",
            "if": "Bash(gh api*pulls*)"
          },
          {
            "type": "command",
            "command": "~/.claude/scripts/guard-env.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/scripts/inject-gh-token.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/cleanup-gh-token.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Codeが許可を求めています\" with title \"Claude Code\" subtitle \"確認待ち\" sound name \"Glass\"'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.py"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "outputStyle": "Explanatory",
  "language": "japanese",
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "autoMemoryEnabled": false
}
