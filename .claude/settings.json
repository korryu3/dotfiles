{
  "cleanupPeriodDays": 9999,
  "permissions": {
    "allow": [
      "Bash(mkdir -p ~/.claude/context/**)",
      "Bash(~/.claude/scripts/project-id.sh)",
      "Read(~/.claude/context/**)",
      "Write(~/.claude/context/**)",
      "Edit(~/.claude/context/**)",
      "MultiEdit(~/.claude/context/**)",
      "Skill(creating-plan)",
      "Skill(resuming-session)",
      "Skill(saving-session)",
      "Skill(skill-creator)",
      "Skill(tdd)",
      "Skill(nvim-sensei)",
      "Skill(reviewing-code)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/guard-pr-posting.sh",
            "if": "Bash(gh pr comment*)"
          },
          {
            "type": "command",
            "command": "~/.claude/scripts/guard-pr-posting.sh",
            "if": "Bash(gh pr review*)"
          },
          {
            "type": "command",
            "command": "~/.claude/scripts/guard-pr-posting.sh",
            "if": "Bash(gh api*pulls*)"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Codeが許可を求めています\" with title \"Claude Code\" subtitle \"確認待ち\" sound name \"Glass\"'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.py"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "language": "japanese",
  "effortLevel": "medium",
  "autoUpdatesChannel": "latest",
  "autoMemoryEnabled": false
}
